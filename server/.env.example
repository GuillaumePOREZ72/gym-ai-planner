# PostgreSQL connection string (Neon — found in your Neon project dashboard)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Neon Auth URL — same as VITE_NEON_AUTH_URL on the client
NEON_AUTH_URL=https://<your-neon-host>/neondb/auth

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Server port
PORT=3001

# Allowed CORS origins (comma-separated for multiple domains)
# Production example: CLIENT_URL=https://app.mydomain.com
CLIENT_URL=http://localhost:5173

# TLS (production only — leave blank for local dev)
# Paths to your Let's Encrypt certificate files
# TLS_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# TLS_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# PUBLIC_DOMAIN: canonical domain for HTTP→HTTPS redirect (prevents open-redirect via Host header)
# PUBLIC_DOMAIN=yourdomain.com
